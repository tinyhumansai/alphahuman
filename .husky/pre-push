#!/usr/bin/env sh
# Run Biome check first (capture exit code without breaking script)
set +e
pnpm check
CHECK_EXIT=$?
set -e

# If check failed, run check:fix to auto-fix
if [ $CHECK_EXIT -ne 0 ]; then
  echo "Code quality issues detected. Running check:fix to auto-fix..."
  pnpm check:fix
fi

# Run TypeScript compile check (capture exit code without breaking script)
set +e
pnpm compile
COMPILE_EXIT=$?
set -e

# Run Rust compile checks for both the core and Tauri codebases
set +e
pnpm rust:check
RUST_CHECK_EXIT=$?
set -e

# Enforce scoped cmd-* tokens in components/commands/
set +e
pnpm --dir app run lint:commands-tokens
CMD_TOKENS_EXIT=$?
set -e

# Exit with error if any command still fails after fixes
if [ $CHECK_EXIT -ne 0 ] || [ $COMPILE_EXIT -ne 0 ] || [ $RUST_CHECK_EXIT -ne 0 ] || [ $CMD_TOKENS_EXIT -ne 0 ]; then
  echo "Pre-push checks failed. Please fix code quality (Biome + cargo fmt for core and Tauri), TypeScript, and/or Rust errors before pushing."
  exit 1
fi
